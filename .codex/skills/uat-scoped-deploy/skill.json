      ],
      "tests": [
        "python3 .codex/skills/codex-skill-authoring/scripts/skill_lint.py"
      ]
    }
  ],
  "handoff_targets": [
    "repo-operations",
    "frontend",
    "backend",
    "backend-api-contracts",
    "security-audit"
  ],
  "adjacent_skills": [
