    "frontend-native-surface-mapper",
    "vault-pkm-governance",
    "quality-contracts"
  ],
  "common_failures": [
    "adding a new screen without cache posture in the manifest",
    "showing a blocking loader when fresh cached data exists",
    "refreshing on unchanged token churn instead of TTL or explicit user action",
    "persisting decrypted PKM or vault secrets outside memory",
    "invalidating cache directly in a component mutation flow",
    "using hardcoded reviewer IDs instead of the reviewer env resolver"
  ]
