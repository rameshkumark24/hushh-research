    "docs/reference/architecture/cache-coherence.md",
    "docs/reference/quality/app-surface-design-system.md"
  ],
  "required_reads": [
    ".codex/skills/frontend-cache-coherence/SKILL.md",
    "docs/reference/architecture/cache-coherence.md",
    "docs/reference/quality/app-surface-design-system.md",
