  "owner_skill": "frontend",
  "default_spoke": "frontend-native-surface-mapper",
  "task_type": "frontend-native-surface-map",
  "affected_surfaces": [
    "hushh-webapp/app",
    "hushh-webapp/app/api",
    "hushh-webapp/lib/services",
    "hushh-webapp/native-route-inventory.json",
