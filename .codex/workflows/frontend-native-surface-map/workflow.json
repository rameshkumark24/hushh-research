  "impact_fields": [
    "Routes touched",
    "Service/API/backend families touched",
    "Native transport or plugin impact",
    "Voice/action contract impact",
    "Verification commands executed"
  ],
  "handoff_chain": [
    "frontend",
    "frontend-native-surface-mapper",
    "frontend-architecture",
    "backend-api-contracts",
    "mobile-parity-audit",
    "kai-voice-governance",
    "docs-governance"
  ],
  "common_failures": [
    "Route calls a new service but the generated map still shows no API dependency",
    "Native route inventory is updated without the surface map",
    "Voice action contract docs reference stale planning docs",
    "A native build assumes a Next.js API server exists"
  ]
