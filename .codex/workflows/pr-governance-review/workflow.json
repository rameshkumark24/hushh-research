{
  "id": "pr-governance-review",
  "title": "PR Governance Review",
  "goal": "Review the current head of an incoming pull request for north-star alignment, trust-boundary regressions, stale-vs-current CI interpretation, and true merge readiness beyond a green gate.",
  "owner_skill": "pr-governance-review",
  "default_spoke": null,
  "task_type": "pr-governance-review",
  "affected_surfaces": [
    ".codex/skills/pr-governance-review",
    ".github",
    "consent-protocol/api",
    "consent-protocol/tests",
    "hushh-webapp/app",
    "hushh-webapp/lib",
    "deploy",
    "scripts"
  ],
  "required_reads": [
    "AGENTS.md",
    "README.md",
    "docs/reference/operations/ci.md",
    "docs/reference/quality/pr-impact-checklist.md",
    "docs/reference/architecture/api-contracts.md",
    ".codex/skills/pr-governance-review/references/review-axes.md",
    ".codex/skills/pr-governance-review/references/runtime-schematics-contract.md",
    ".codex/skills/pr-governance-review/references/operator-batch-output-contract.md",
    ".codex/skills/pr-governance-review/references/comment-and-report-contract.md",
    ".codex/skills/pr-governance-review/references/pr-train-review-sop.md",
    ".codex/skills/repo-operations/SKILL.md"
  ],
  "required_commands": [
    "python3 .codex/skills/agent-orchestration-governance/scripts/delegation_router.py --workflow pr-governance-review --phase start --prompt \"<user request>\" --paths \"<changed paths>\" --text",
    "python3 .codex/skills/pr-governance-review/scripts/build_runtime_schematics.py --text",
    "python3 .codex/skills/pr-governance-review/scripts/pr_review_checklist.py --repo hushh-labs/hushh-research --pr <number> --text",
    "python3 .codex/skills/pr-governance-review/scripts/pr_review_checklist.py --repo hushh-labs/hushh-research --live-report --scan-mode hybrid --selection-order oldest --limit 100 --candidate-limit 40 --text --output tmp/pr-governance-live-report.md",
    "./bin/hushh codex audit --text"
  ],
  "verification_bundle": {
    "id": "pr-governance-review",
    "commands": [
      "python3 -m py_compile .codex/skills/agent-orchestration-governance/scripts/delegation_router.py",
      "python3 -m py_compile .codex/skills/pr-governance-review/scripts/pr_review_checklist.py",
      "python3 -m py_compile .codex/skills/pr-governance-review/scripts/build_runtime_schematics.py",
      "python3 .codex/skills/agent-orchestration-governance/scripts/delegation_router.py --workflow pr-governance-review --phase start --prompt \"review a PR touching voice, vault, and CI\" --paths \"hushh-webapp/lib/voice/foo.ts,hushh-webapp/lib/vault/foo.ts,.github/workflows/ci.yml\" --text",
      "python3 .codex/skills/pr-governance-review/scripts/build_runtime_schematics.py --text",
      "./bin/hushh codex audit --text",
      "./bin/hushh docs verify"
    ],
    "tests": [
      "python3 -m py_compile .codex/skills/agent-orchestration-governance/scripts/delegation_router.py",
      "python3 -m py_compile .codex/skills/pr-governance-review/scripts/pr_review_checklist.py",
      "python3 -m py_compile .codex/skills/pr-governance-review/scripts/build_runtime_schematics.py",
      "python3 .codex/skills/agent-orchestration-governance/scripts/delegation_router.py --workflow pr-governance-review --phase start --prompt \"review a PR touching voice, vault, and CI\" --paths \"hushh-webapp/lib/voice/foo.ts,hushh-webapp/lib/vault/foo.ts,.github/workflows/ci.yml\" --text",
      "python3 .codex/skills/pr-governance-review/scripts/build_runtime_schematics.py --text",
      "./bin/hushh codex audit --text",
      "./bin/hushh docs verify"
    ]
  },
  "deliverables": [
    "delegation router decision and any read-only evidence lanes spawned",
    "current-head SHA review summary",
    "repo-derived runtime schematics provenance",
    "async train graph with queue cohorts, collision groups, patch trains, and decision waves for multi-PR work",
    "subagent taskforce evidence map and five-worker refill pool for async train sessions",
    "blocker-first findings list",
    "stale-vs-current CI interpretation",
    "merge lane recommendation",
    "explicit action flow mode",
    "lane-to-comment-map decision for every GitHub write",
    "natural technical GitHub review note",
    "updated working report after PR state changes"
  ],
  "impact_fields": [
    "Delegation decision",
    "Subagent evidence lanes used or skipped",
    "Head SHA reviewed",
    "Current CI Status Gate state",
    "Current reviewDecision state",
    "Runtime schematics source coverage",
    "Blocker findings",
    "Chosen merge lane",
    "Action flow mode",
    "Working report updated",
    "Docs updated",
    "Verification commands executed"
  ],
  "handoff_chain": [
    "pr-governance-review",
    "repo-operations",
    "quality-contracts",
    "backend-runtime-governance",
    "frontend-architecture",
    "security-audit"
  ],
  "delegation_policy": {
    "auto_spawn_read_only_evidence_lanes": true,
    "router": ".codex/skills/agent-orchestration-governance/scripts/delegation_router.py",
    "phase_checkpoints": [
      "start",
      "mid"
    ],
    "parent_only_actions": [
      "branch switching",
      "patching",
      "approval",
      "merge",
      "deploy",
      "secrets"
    ],
    "writer_lane_exception": {
      "scope": "pr-governance-review",
      "executor": "workflow-local-pr-train-worker",
      "allowed_actions": [
        "edit_standardized_maintainer_comment",
        "post_standardized_maintainer_comment",
        "request_changes",
        "close_superseded_pr",
        "acknowledge_harvest",
        "enqueue_exact_head_queue_candidate"
      ],
      "required_gates": [
        "operator_approved_train_set",
        "exact_head_sha",
        "green_ci_status_gate",
        "clean_mergeability",
        "no_hard_collision_edge",
        "comment_and_report_contract"
      ],
      "forbidden_actions": [
        "branch_switching",
        "commits",
        "pushes",
        "code_patches",
        "secrets",
        "deploys",
        "direct_merge_to_main",
        "product_policy_changes",
        "unsafe_contributor_head_merge"
      ],
      "drift_returns_to_parent": [
        "head_sha_changed",
        "ci_state_lost",
        "new_conflict",
        "failing_check",
        "lost_canonical_attach_point"
      ]
    },
    "lanes": {
      "analytics/observability": {
        "agent": "analytics_observability_architect",
        "reasoning_effort": "high"
      },
      "voice/action": {
        "agent": "voice_systems_architect",
        "reasoning_effort": "xhigh"
      },
      "security/consent/vault/pkm": {
        "agent": "security_consent_auditor",
        "reasoning_effort": "xhigh"
      },
      "regression/proof": {
        "agent": "reviewer",
        "reasoning_effort": "xhigh"
      },
      "backend/contracts": {
        "agent": "backend_architect",
        "reasoning_effort": "high"
      },
      "data-model/schema/uat": {
        "agent": "data_model_architect",
        "reasoning_effort": "xhigh"
      },
      "frontend/reachability": {
        "agent": "frontend_architect",
        "reasoning_effort": "high"
      },
      "mobile/native": {
        "agent": "mobile_native_architect",
        "reasoning_effort": "high"
      },
      "product/docs/founder-language": {
        "agent": "product_docs_architect",
        "reasoning_effort": "xhigh"
      },
      "ci/deploy/release": {
        "agent": "repo_operator",
        "reasoning_effort": "high"
      },
      "failure/rca": {
        "agent": "rca_investigator",
        "reasoning_effort": "high"
      }
    }
  },
  "common_failures": [
    "reviewing a stale failed run instead of the current head SHA",
    "treating green CI as sufficient proof for a sensitive contract change",
    "missing backend-to-caller contract drift because only one side of the change moved",
    "thanking or merging before blocker findings are explicitly cleared",
    "merging a directionally good but currently unsafe contributor head instead of using the patch-then-merge lane",
    "treating approve-only as implicit merge authority",
    "using rigid template comments when a concise technical note would be clearer",
    "leaving the PR governance live report stale after merge, close, or supersede",
    "running backlog-scale PR trains without router-selected read-only evidence lanes",
    "planning executable trains around PRs with failing, missing, stale, or auxiliary-failing checks",
    "treating independent PR trains as sequential just because they are in the same review session"
  ]
}
