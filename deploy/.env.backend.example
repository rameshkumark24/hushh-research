# Backend Environment Variables Template
# Copy this to .env.backend and fill in production values

# ============================================================================
# PRODUCTION CONFIGURATION
# ============================================================================

# Environment
ENVIRONMENT=production
PORT=8080
OTEL_ENABLED=false

# Frontend URL (UPDATE AFTER FRONTEND DEPLOYMENT)
# This is used for CORS configuration
APP_FRONTEND_ORIGIN=https://hushh-webapp-XXXXXXXXXX-uc.a.run.app
# Comma-separated explicit origin allowlist (no wildcard regex in regulated mode)
CORS_ALLOWED_ORIGINS=https://hushh-webapp-XXXXXXXXXX-uc.a.run.app

# ============================================================================
# SECRETS (Managed via Google Cloud Secret Manager)
# ============================================================================
# DO NOT set these here - they are injected from Secret Manager
# Listed here for documentation purposes only

# APP_SIGNING_KEY=<at least 32 chars; 64-char hex recommended — signing/state integrity only>
# VAULT_DATA_KEY=<exactly 64-char hex — vault/PKM data encryption only>
# GOOGLE_API_KEY=<Google Gemini API key>
# AGENT_GEMINI_MODEL=gemini-2.5-pro
# FIREBASE_ADMIN_CREDENTIALS_JSON=<Firebase Admin SDK JSON>
# Optional compatibility alias only. Prefer FIREBASE_ADMIN_CREDENTIALS_JSON.
# FIREBASE_SERVICE_ACCOUNT_JSON=<Firebase Admin SDK JSON>
# One/Workspace Gmail delegation uses the Firebase Admin service account client 109021324828349644970.
# ONE_EMAIL_ADDRESS=one@hushh.ai
# ONE_EMAIL_DELEGATED_USER=one@hushh.ai
# ONE_EMAIL_PUBSUB_TOPIC=projects/<project-id>/topics/one-email-gmail
# ONE_EMAIL_WEBHOOK_AUDIENCE=https://<backend-host>/api/one/email/webhook
# ONE_EMAIL_WEBHOOK_SERVICE_ACCOUNT_EMAIL=<pubsub-push-service-account>@<project-id>.iam.gserviceaccount.com
# ONE_EMAIL_WEBHOOK_AUTH_ENABLED=true
# ONE_EMAIL_WATCH_LABEL_IDS=INBOX
# ONE_EMAIL_WATCH_RENEW_TOKEN=<secret-manager-injected-maintenance-token>
# ONE_EMAIL_WATCH_RENEW_AUTH_ENABLED=true
# ONE_EMAIL_KYC_STRICT_CLIENT_ZK_ENABLED=true
# ONE_EMAIL_KYC_DEFAULT_SCOPE=attr.identity.*
# SUPPORT_EMAIL_DELEGATED_USER=one@hushh.ai
# SUPPORT_EMAIL_FROM=one@hushh.ai
# SUPPORT_EMAIL_TO=one@hushh.ai
# SUPPORT_EMAIL_TEST_TO=<maintainer inbox for non-production test sends>
# SUPPORT_EMAIL_MODE=test
# UAT only: fixed-code phone verification allowlist for reviewer/test flows.
# HUSHH_UAT_PHONE_TEST_NUMBERS=+16505550101,+16505550102
# HUSHH_UAT_PHONE_TEST_CODE=<secret fixed OTP>
# HUSHH_UAT_PHONE_TEST_CHALLENGE_SECRET=<optional HMAC key; defaults to APP_SIGNING_KEY>
# DB_USER=<Supabase pooler username, e.g., postgres.project-ref>
# DB_PASSWORD=<Database password>
# BACKEND_RUNTIME_CONFIG_JSON=<JSON blob for runtime policy such as DB socket settings, CORS, remote toggles, and Plaid runtime values>
# VOICE_RUNTIME_CONFIG_JSON=<JSON blob for voice rollout, model defaults, and fallback policy>
# FINNHUB_API_KEY=<Finnhub API key>
# PMP_API_KEY=<PMP/FMP API key>
# FMP_API_KEY=<FMP API key (optional alias)>
# IAPD_VERIFY_BASE_URL=<Official advisory verification worker base URL>
# IAPD_VERIFY_API_KEY=<Official advisory verification worker API key>
# Optional intelligence verifier (runs before IAPD fallback):
# RIA_INTELLIGENCE_VERIFY_BASE_URL=<RIA intelligence API base URL, e.g. https://...run.app>
# RIA_INTELLIGENCE_VERIFY_API_KEY=<Bearer token if intelligence API is protected>
# RIA_INTELLIGENCE_VERIFY_TIMEOUT_SECONDS=25

# ============================================================================
# DATABASE CONFIGURATION (Supabase Session Pooler)
# ============================================================================
# Uses individual DB_* environment variables for Supabase connection pooling
# DB_HOST, DB_PORT, DB_NAME are set as Cloud Run env vars (not secrets)
# DB_USER and DB_PASSWORD are injected from Secret Manager
#
# Example values:
# DB_HOST=aws-1-us-east-1.pooler.supabase.com
# DB_PORT=5432
# DB_NAME=postgres

# ============================================================================
# TOKEN EXPIRATION (milliseconds)
# ============================================================================
DEFAULT_CONSENT_TOKEN_EXPIRY_MS=604800000    # 7 days
DEFAULT_TRUST_LINK_EXPIRY_MS=2592000000      # 30 days

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
AGENT_ID=agent_hushh_production
HUSHH_HACKATHON=disabled

# Regulated defaults
CONSENT_SSE_ENABLED=false
SYNC_REMOTE_ENABLED=false
DEVELOPER_API_ENABLED=false
OBS_DATA_STALE_RATIO_THRESHOLD=0.25

# Non-production only: runtime registry for /api/v1 developer API
# DEVELOPER_REGISTRY_JSON={"mcp_dev_local":{"name":"MCP Local","approved_scopes":["*"]}}

# Service auth for protected lookup endpoints
# HUSHH_DEVELOPER_TOKEN=<high-entropy developer token>

# ============================================================================
# NOTES
# ============================================================================
# 1. Secrets are managed via Google Cloud Secret Manager
# 2. Use scripts/ops/verify-env-secrets-parity.py to verify all secrets exist
# 3. DB_USER and DB_PASSWORD are injected from Secret Manager
# 4. DB_HOST, DB_PORT, DB_NAME are set as Cloud Run env vars
# 5. Reviewer secrets belong in maintainer-only overlays locally, but UAT mounts
#    REVIEWER_UID / REVIEWER_VAULT_PASSPHRASE from Secret Manager for app-review smoke
