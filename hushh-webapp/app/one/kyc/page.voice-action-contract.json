{
  "schema_version": "kai.local_action_contract.v1",
  "surface_id": "one_kyc",
  "surface_title": "One KYC Workflows",
  "docs_references": [
    "docs/reference/kai/kai-action-gateway-vnext.md",
    "docs/reference/architecture/one-email-kyc.md",
    "docs/reference/architecture/frontend-native-surface-map.md"
  ],
  "defaults": {
    "reachability": {
      "routes": [
        "/one/kyc"
      ],
      "screens": [
        "one_kyc"
      ],
      "active_personas": [
        "investor"
      ],
      "navigation_prerequisites": [
        "user must be signed in"
      ]
    },
    "speaker_persona": "kyc",
    "delegate_agent_id": "kyc"
  },
  "actions": [
    {
      "action_id": "route.one_kyc",
      "label": "Open KYC Workflows",
      "meaning": "Navigates to One KYC workflow review.",
      "aliases": [
        "open kyc",
        "open one kyc",
        "show kyc workflows"
      ],
      "search_keywords": [
        "kyc",
        "one",
        "broker"
      ],
      "reachability": {
        "hidden_navigable": false
      },
      "guard_ids": [
        "auth_required"
      ],
      "risk_level": "low",
      "execution_policy": "allow_direct",
      "execution_target": {
        "status": "wired",
        "path": "route",
        "target": "/one/kyc"
      },
      "control_ids": [
        "one-kyc-open"
      ],
      "state_exposure": [
        "workflow list metadata only"
      ]
    },
    {
      "action_id": "kyc.workflow.sync_status",
      "label": "Sync KYC Status",
      "meaning": "Refreshes the selected One KYC workflow status after consent approval.",
      "aliases": [
        "sync kyc",
        "refresh kyc status"
      ],
      "search_keywords": [
        "kyc",
        "sync",
        "consent"
      ],
      "guard_ids": [
        "auth_required"
      ],
      "risk_level": "medium",
      "execution_policy": "manual_only",
      "execution_target": {
        "status": "unwired",
        "reason": "Requires selected workflow context from /one/kyc."
      },
      "control_ids": [
        "one-kyc-sync-status"
      ],
      "state_exposure": [
        "workflow status metadata"
      ]
    },
    {
      "action_id": "kyc.draft.review",
      "label": "Review KYC Draft",
      "meaning": "Reads or focuses the current approval-gated KYC draft.",
      "aliases": [
        "review kyc draft",
        "show kyc draft"
      ],
      "search_keywords": [
        "kyc",
        "draft",
        "review"
      ],
      "guard_ids": [
        "auth_required"
      ],
      "risk_level": "medium",
      "execution_policy": "manual_only",
      "execution_target": {
        "status": "unwired",
        "reason": "Requires selected workflow context and user-visible draft state."
      },
      "control_ids": [
        "one-kyc-draft-review"
      ],
      "state_exposure": [
        "approved draft body"
      ]
    },
    {
      "action_id": "kyc.draft.request_redraft",
      "label": "Request KYC Redraft",
      "meaning": "Requests a new KYC draft revision from typed or spoken user instructions.",
      "aliases": [
        "redraft kyc",
        "revise kyc draft"
      ],
      "search_keywords": [
        "kyc",
        "redraft",
        "revise"
      ],
      "guard_ids": [
        "auth_required"
      ],
      "risk_level": "medium",
      "execution_policy": "confirm_required",
      "execution_target": {
        "status": "unwired",
        "reason": "Requires selected workflow context and captured redraft instructions."
      },
      "control_ids": [
        "one-kyc-redraft"
      ],
      "state_exposure": [
        "approved draft body",
        "redraft instructions"
      ]
    },
    {
      "action_id": "kyc.draft.approve_send",
      "label": "Approve KYC Send",
      "meaning": "Sends the KYC draft only after explicit user approval.",
      "aliases": [
        "approve kyc send",
        "send kyc reply"
      ],
      "search_keywords": [
        "kyc",
        "send",
        "approve"
      ],
      "guard_ids": [
        "auth_required",
        "explicit_confirmation_required"
      ],
      "risk_level": "high",
      "execution_policy": "manual_only",
      "execution_target": {
        "status": "unwired",
        "reason": "Voice must not send mail until the selected workflow and explicit confirmation are wired to the same UI approval endpoint."
      },
      "control_ids": [
        "one-kyc-approve-send"
      ],
      "state_exposure": [
        "approved draft body",
        "send status"
      ]
    },
    {
      "action_id": "kyc.draft.reject",
      "label": "Reject KYC Draft",
      "meaning": "Rejects the current KYC draft and blocks the workflow.",
      "aliases": [
        "reject kyc draft",
        "block kyc workflow"
      ],
      "search_keywords": [
        "kyc",
        "reject",
        "block"
      ],
      "guard_ids": [
        "auth_required"
      ],
      "risk_level": "medium",
      "execution_policy": "confirm_required",
      "execution_target": {
        "status": "unwired",
        "reason": "Requires selected workflow context from /one/kyc."
      },
      "control_ids": [
        "one-kyc-reject"
      ],
      "state_exposure": [
        "workflow status metadata"
      ]
    }
  ]
}
