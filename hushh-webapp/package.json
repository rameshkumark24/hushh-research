    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "gsap": "^3.15.0",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
