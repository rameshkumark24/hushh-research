    "jsdom": "^25.0.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@google-cloud/storage": "7.19.0",
